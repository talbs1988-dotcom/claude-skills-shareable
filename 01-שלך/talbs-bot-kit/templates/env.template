# Environment Variables — Personal WhatsApp Bot
# הוקם ב-{{INSTALLED_DATE}} עבור {{USER_NAME}}
#
# ⚠️ אסור לשתף את הקובץ הזה עם אף אחד.
# אם דולף — מיד שני את כל המפתחות בכל השירותים.

# ===== Bot Identity =====
USER_NAME={{USER_NAME}}
USER_WHATSAPP_NUMBER={{USER_WHATSAPP_NUMBER}}
USER_WHATSAPP_JID={{USER_WHATSAPP_NUMBER}}@s.whatsapp.net

# ===== Green API (WhatsApp) =====
GREEN_API_INSTANCE_ID={{GREEN_API_INSTANCE_ID}}
GREEN_API_TOKEN={{GREEN_API_TOKEN}}

# ===== Anthropic (Claude) =====
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}

# ===== Airtable (CRM) =====
# Personal Access Token from https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_PAT={{AIRTABLE_API_KEY}}
AIRTABLE_API_KEY={{AIRTABLE_API_KEY}}
AIRTABLE_BASE_ID={{AIRTABLE_BASE_ID}}
TABLE_LEADS_ID={{TABLE_LEADS_ID}}
TABLE_TASKS_ID={{TABLE_TASKS_ID}}
TABLE_TRANSACTIONS_ID={{TABLE_TRANSACTIONS_ID}}

# ===== Google Calendar (Secret iCal URL) — for morning agenda script =====
# In Google Calendar: Settings → choose your calendar → Integrate calendar
# → Secret address in iCal format. Read-only access.
GOOGLE_CALENDAR_ICAL_URL={{GOOGLE_CALENDAR_ICAL_URL}}

# ===== Green Invoice (חשבונית ירוקה) — optional =====
# (יישאר ריק אם HAS_INVOICES=false)
GREENINVOICE_API_KEY={{GREENINVOICE_API_KEY}}
GREENINVOICE_API_SECRET={{GREENINVOICE_API_SECRET}}

# ===== Bot Configuration =====
BOT_HTTP_PORT=7654
PORT=7654
NTFY_TOPIC={{NTFY_TOPIC}}
TZ=Asia/Jerusalem

# ===== Claude CLI =====
# Path to claude binary. Leave as "claude" if it's in PATH.
# On Mac via Anthropic installer: /Users/[name]/.local/bin/claude
CLAUDE_BIN=claude
